# AI provider
# Any OpenAI-compatible /chat/completions provider can be used here.
AI_DEFAULT_PROVIDER=custom
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=your-api-key
AI_MODEL_NAME=your-model-name

# Optional provider-specific aliases.
# Set AI_DEFAULT_PROVIDER=deepseek to use these values.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# Set AI_DEFAULT_PROVIDER=qwen to use these values.
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus

# LLM request options
AI_TIMEOUT=60
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# Server
PORT=5000
FLASK_DEBUG=true
